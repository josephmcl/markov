Grammar

    0 $accept: program $end

    1 program: statements

    2 statements: %empty
    3           | statements statementz
    4           | statements statementz PERIOD

    5 function: LBRACKET RBRACKET LCURL statements RCURL

    6 u_inherited_scope_names: %empty
    7                        | inherited_scope_names
    8                        | EQUAL
    9                        | ATSIGN

   10 inherited_scope_names: inherited_scope_name
   11                      | inherited_scope_names COMMA inherited_scope_name

   12 inherited_scope_name: IDENTIFIER
   13                     | inherited_scope_name DOUBLE_COLON IDENTIFIER

   14 statementz: statement
   15           | statementz SEMICOLON statement
   16           | statementz COMMA statement

   17 statement: assignment_statement
   18          | import_statement
   19          | r_expression
   20          | function
   21          | scope
   22          | algorithm
   23          | algorithm_call
   24          | equivalence_statement

   25 scope: scope_export scope_module scope_name LCURL statements RCURL
   26      | scope_context scope_name LCURL statements RCURL
   27      | scope_export scope_context scope_name LCURL statements RCURL

   28 scope_export: EN_EXPORT

   29 scope_module: EN_MODULE

   30 scope_name: %empty
   31           | IDENTIFIER

   32 scope_context: LANGLE u_inherited_scope_names RANGLE

   33 assignment_statement: l_expression EQUAL r_expression

   34 import_statement: EN_IMPORT EN_MODULE IDENTIFIER

   35 l_expression: variable

   36 variable: IDENTIFIER

   37 r_expression: alphabet_body
   38             | extends_expression
   39             | union_expression
   40             | intersect_expression
   41             | difference_expression
   42             | word_literal
   43             | word_in_expression
   44             | abstract_size
   45             | abstract_alphabet
   46             | abstract_named
   47             | range_literal
   48             | range_function
   49             | bind_expression
   50             | bind_rules_value
   51             | variable

   52 extends_expression: r_expression EXTENDS r_expression
   53                   | r_expression EN_EXTENDS r_expression

   54 union_expression: r_expression UNION r_expression
   55                 | r_expression EN_UNION r_expression

   56 intersect_expression: r_expression INTERSECT r_expression
   57                     | r_expression EN_INTERSECT r_expression

   58 difference_expression: r_expression BACKSLASH r_expression
   59                      | r_expression EN_DIFFERENCE r_expression

   60 alphabet_body: LCURL u_letters RCURL

   61 u_letters: %empty
   62          | letters

   63 letters: letter
   64        | letters COMMA letter

   65 letter: IDENTIFIER

   66 word_literal: STRING_LITERAL

   67 word_in_expression: word_literal IN r_expression
   68                   | word_literal EN_IN r_expression

   69 range_literal: NUMBER PERIOD PERIOD NUMBER

   70 range_function: IDENTIFIER LPAREN NUMBER COMMA NUMBER COMMA NUMBER RPAREN

   71 abstract_size: LBRACKET NUMBER RBRACKET

   72 abstract_alphabet: abstract_size PLUS alphabet_body

   73 abstract_named: LBRACKET abstract_name_list RBRACKET

   74 abstract_name_list: IDENTIFIER COMMA IDENTIFIER
   75                   | abstract_name_list COMMA IDENTIFIER

   76 algorithm_name: IDENTIFIER

   77 algorithm: algorithm_name DOUBLE_COLON variable LCURL algorithm_rules RCURL
   78          | algorithm_name DOUBLE_COLON abstract_size LCURL algorithm_rules RCURL
   79          | algorithm_name DOUBLE_COLON abstract_named LCURL algorithm_rules RCURL
   80          | algorithm_name DOUBLE_COLON LBRACKET r_expression RBRACKET TILDE IDENTIFIER
   81          | algorithm_name DOUBLE_COLON LBRACKET r_expression RBRACKET APPROX IDENTIFIER
   82          | algorithm_name DOUBLE_COLON LBRACKET r_expression RBRACKET DOUBLE_TILDE IDENTIFIER

   83 algorithm_rules: %empty
   84                | algorithm_rule
   85                | algorithm_rules SEMICOLON algorithm_rule

   86 algorithm_rule: pattern ARROW pattern
   87               | pattern TERMINAL
   88               | pattern EMIT_ARROW pattern COLON STRING_LITERAL
   89               | pattern EMIT_ARROW pattern
   90               | pattern EMIT_TERMINAL COLON STRING_LITERAL
   91               | pattern EMIT_TERMINAL
   92               | IDENTIFIER COLON pattern ARROW pattern
   93               | IDENTIFIER COLON pattern TERMINAL
   94               | IDENTIFIER COLON pattern EMIT_ARROW pattern COLON STRING_LITERAL
   95               | IDENTIFIER COLON pattern EMIT_ARROW pattern
   96               | IDENTIFIER COLON pattern EMIT_TERMINAL COLON STRING_LITERAL
   97               | IDENTIFIER COLON pattern EMIT_TERMINAL

   98 pattern: IDENTIFIER
   99        | pattern IDENTIFIER

  100 algorithm_call: IDENTIFIER LPAREN STRING_LITERAL RPAREN
  101               | IDENTIFIER LPAREN IDENTIFIER RPAREN
  102               | IDENTIFIER LPAREN TILDE RPAREN

  103 bind_rules_value: LCURL bind_rules_list RCURL

  104 bind_expression: r_expression BIND r_expression
  105                | r_expression COLON LBRACKET bind_rules_list RBRACKET RANGLE r_expression

  106 bind_rules_list: bind_rule
  107                | IDENTIFIER
  108                | bind_rules_list COMMA bind_rule

  109 bind_rule: IDENTIFIER COLON IDENTIFIER
  110          | IDENTIFIER COLON
  111          | IDENTIFIER PERIOD IDENTIFIER
  112          | EXCLAIM IDENTIFIER

  113 equivalence_statement: algorithm_name RULE_EQ algorithm_name
  114                      | IDENTIFIER DOUBLE_COLON LBRACKET r_expression RBRACKET TILDE IDENTIFIER
  115                      | IDENTIFIER DOUBLE_COLON LBRACKET r_expression RBRACKET APPROX IDENTIFIER
  116                      | IDENTIFIER DOUBLE_COLON LBRACKET r_expression RBRACKET DOUBLE_TILDE IDENTIFIER


